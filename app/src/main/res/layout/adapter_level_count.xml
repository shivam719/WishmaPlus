<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/total"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:text="Total Follower : "
        android:textColor="@color/grey_6"
        app:layout_constraintEnd_toStartOf="@id/totalCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/totalCount"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/colorPrimaryLight"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/total"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/total"
        app:layout_constraintTop_toTopOf="@id/total" />
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/level"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Follower : "
        android:textColor="@color/grey_6"
        app:layout_constraintEnd_toStartOf="@id/levelCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/levelCount"
        app:layout_constraintTop_toTopOf="@id/levelCount" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/levelCount"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="@dimen/_20sdp"
        android:layout_height="@dimen/_20sdp"
        android:layout_marginTop="@dimen/_7sdp"
        android:background="@drawable/circle_background"
        android:backgroundTint="@color/colorPrimaryLight"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="@android:color/white"
        app:layout_constraintStart_toEndOf="@id/level"
        app:layout_constraintTop_toBottomOf="@id/total" />


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/active"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_7sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:text="Activate"
        android:textColor="@color/grey_6"
        app:layout_constraintEnd_toStartOf="@id/deactive"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/levelCount" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/activeCount"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_5sdp"
        android:drawablePadding="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@android:color/holo_green_dark"
        app:drawableStartCompat="@drawable/ic_check_circle"
        app:layout_constraintEnd_toStartOf="@id/deactiveCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/active" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/deactive"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_7sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:text="Deactivate"
        android:textColor="@color/grey_6"
        app:layout_constraintEnd_toStartOf="@id/viewIncome"
        app:layout_constraintStart_toEndOf="@id/active"
        app:layout_constraintTop_toBottomOf="@id/levelCount" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/deactiveCount"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:drawablePadding="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@android:color/holo_red_dark"
        app:drawableStartCompat="@drawable/ic_cross_circle"
        app:layout_constraintEnd_toStartOf="@id/viewIncome"
        app:layout_constraintStart_toEndOf="@id/activeCount"
        app:layout_constraintTop_toBottomOf="@id/deactive" />
<!--Static Gone -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/viewIncome"
        android:visibility="gone"
        style="@style/TextAppearance.AppCompat.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/_3sdp"
        android:paddingHorizontal="@dimen/_5sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:backgroundTint="@color/colorAccent"
        android:text="View Income"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:cornerRadius="@dimen/_5sdp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="@id/deactiveCount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/deactive" />

    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_2sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/deactiveCount" />
</androidx.constraintlayout.widget.ConstraintLayout>