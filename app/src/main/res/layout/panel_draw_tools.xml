<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="38dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/drag_handle_bg" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Draw"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDrawDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_blue_bg"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="Done"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tool row -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never"
        android:paddingHorizontal="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/toolBrush"
                style="@style/DrawTool"
                android:alpha="1.0"
                android:src="@drawable/ic_brush" />

            <ImageView
                android:id="@+id/toolPen"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/ic_edit" />

            <ImageView
                android:id="@+id/toolHighlighter"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/ic_highlight" />

            <ImageView
                android:id="@+id/toolEraser"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/ic_eraser" />

            <ImageView
                android:id="@+id/toolLine"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/ic_remove" />

            <ImageView
                android:id="@+id/toolRect"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/ic_crop_square" />

            <ImageView
                android:id="@+id/toolCircle"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/circle_bg" />

            <ImageView
                android:id="@+id/toolArrow"
                style="@style/DrawTool"
                android:alpha="0.5"
                android:src="@drawable/ic_arrow_forward" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginVertical="10dp"
        android:background="#222222" />

    <!-- Color strip -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never"
        android:paddingHorizontal="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/drawColorStrip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="6dp" />
    </HorizontalScrollView>

    <!-- Size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_brush"
            app:tint="@color/black" />

        <SeekBar
            android:id="@+id/drawSizeBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:max="60"
            android:progress="8"
            android:progressTint="@color/black"
            android:thumbTint="@color/black" />
    </LinearLayout>

    <!-- Opacity -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_opacity"
            app:tint="@color/black" />

        <SeekBar
            android:id="@+id/drawOpacityBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="100"
            android:progressTint="@color/black"
            android:thumbTint="@color/black" />
    </LinearLayout>

    <!-- Undo / Redo / Clear -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp">

        <ImageView
            android:id="@+id/btnDrawUndo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_outline"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_undo"
            app:tint="@color/black" />

        <ImageView
            android:id="@+id/btnDrawRedo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_outline"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_redo"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/btnDrawClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_blue_bg"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="18dp"
            android:paddingVertical="8dp"
            android:text="Clear All"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
