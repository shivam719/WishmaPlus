<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingBottom="@dimen/_10sdp">

    <ImageView
        android:id="@+id/cover_photo"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_155sdp"
        android:scaleType="centerCrop"
        android:src="@drawable/dog_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/edit_cover_icon"
        android:layout_width="@dimen/_35sdp"
        android:layout_height="@dimen/_35sdp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="@dimen/_15sdp"
        android:background="@drawable/circle_background_white"
        android:contentDescription="Edit Cover Photo"
        android:src="@drawable/ic_camera"
        app:layout_constraintBottom_toBottomOf="@id/cover_photo"
        app:layout_constraintEnd_toEndOf="@id/cover_photo" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/profile_picture"
        android:layout_width="@dimen/_115sdp"
        android:layout_height="@dimen/_115sdp"
        android:layout_centerInParent="true"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_minus40sdp"
        android:background="@drawable/circle_background"
        android:padding="@dimen/_2sdp"
        android:scaleType="centerCrop"
        android:src="@drawable/user_icon"
        app:layout_constraintBottom_toBottomOf="@id/cover_photo"
        app:layout_constraintStart_toStartOf="@id/cover_photo" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/edit_profile_icon"
        android:layout_width="@dimen/_36sdp"
        android:layout_height="@dimen/_36sdp"
        android:layout_alignRight="@id/profile_picture"
        android:layout_alignBottom="@id/profile_picture"
        android:layout_marginRight="8dp"
        android:background="@drawable/circle_background_white"
        android:padding="@dimen/_8sdp"
        android:src="@drawable/ic_camera"
        app:layout_constraintBottom_toBottomOf="@id/profile_picture"
        app:layout_constraintEnd_toEndOf="@id/profile_picture" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/packageImage"
        android:layout_width="@dimen/_28sdp"
        android:layout_height="@dimen/_28sdp"
        android:layout_marginStart="@dimen/_130sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="@id/packageName"
        app:layout_constraintEnd_toStartOf="@id/packageName"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/packageTitle" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/packageTitle"
        style="@style/TextAppearance.AppCompat.Caption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginTop="@dimen/_7sdp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-condensed-medium"
        android:maxLines="1"
        android:text="@string/current_package"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toEndOf="@id/packageName"
        app:layout_constraintStart_toStartOf="@id/packageName"
        app:layout_constraintTop_toBottomOf="@id/cover_photo" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/packageName"
        style="@style/TextAppearance.AppCompat.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginTop="@dimen/_2sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-condensed-medium"
        android:maxLines="1"
        android:minWidth="@dimen/_60sdp"
        android:text="Package Name"
        android:textColor="@android:color/holo_green_dark"
        android:textStyle="bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1"
        app:layout_constraintStart_toEndOf="@id/packageImage"
        app:layout_constraintTop_toBottomOf="@id/packageTitle" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/user_name"
        style="@style/TextAppearance.AppCompat.Title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:text="User Name"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/profile_picture" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/bioTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_4sdp"
        android:text="User Name"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/user_name" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/followersView"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:backgroundTint="@color/bgColor"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="followers"
        android:textColor="@color/grey_6"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bioTv" />
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/dotView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="•"
        android:textColor="@color/grey_6"
        android:textSize="@dimen/_12sdp"
        android:layout_marginStart="@dimen/_5sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        app:layout_constraintStart_toEndOf="@id/followersView"
        app:layout_constraintTop_toTopOf="@id/followersView"
        app:layout_constraintBottom_toBottomOf="@id/followersView"/>


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/followingView"
        style="@style/TextAppearance.AppCompat.Subhead"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="following"
        android:textColor="@color/grey_6"
        app:layout_constraintStart_toEndOf="@id/dotView"
        app:layout_constraintTop_toTopOf="@id/followersView"
        app:layout_constraintBottom_toBottomOf="@id/followersView" />


    <!-- <com.google.android.material.button.MaterialButton
