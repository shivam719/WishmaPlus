<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_corners_top">

    <TextView
        android:id="@+id/title"
        style="@style/TextAppearance.AppCompat.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/all_features"
        android:textColor="@android:color/black"
        app:layout_constraintBottom_toBottomOf="@id/back_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/back_button" />

    <ImageButton
        android:id="@+id/back_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_5sdp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:padding="@dimen/_10sdp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_1sdp"
        android:layout_below="@id/back_button"
        android:background="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_button" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/packageIcon"
        android:layout_width="@dimen/_60sdp"
        android:layout_height="@dimen/_60sdp"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/line"
        app:srcCompat="@drawable/ic_package" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/packageTv"
        style="@style/TextAppearance.AppCompat.Medium"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_15sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/packageIcon" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/packageAmt"
        style="@style/TextAppearance.AppCompat.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/packageTv"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/packageTime"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/packageTv" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/packageTime"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/packageTv"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/packageAmt"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toEndOf="@id/packageAmt" />
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/expireIn"
        style="@style/TextAppearance.AppCompat.Caption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/packageTv"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textStyle="bold"
        android:textColor="@android:color/holo_red_dark"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/packageAmt" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/packageNoteTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/packageTv"
        android:layout_marginTop="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/expireIn" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/dailyPostLimitLabel"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_20sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:text="@string/daily_post_limit"
        android:textColor="@android:color/black"
        app:layout_constraintEnd_toStartOf="@id/dailyPostLimit"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/packageNoteTv" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/dailyPostLimit"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:textColor="@android:color/holo_green_dark"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/dailyPostLimitLabel"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toEndOf="@id/dailyPostLimitLabel"
        app:layout_constraintTop_toTopOf="@id/dailyPostLimitLabel" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/textPost"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:drawablePadding="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:text="@string/you_can_post_text"
        android:textColor="@android:color/black"
        app:drawableEndCompat="@drawable/ic_check_circle"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/dailyPostLimitLabel" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/imagePost"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:drawablePadding="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:text="@string/you_can_post_image"
        android:textColor="@android:color/black"
        app:drawableEndCompat="@drawable/ic_check_circle"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/textPost" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/videoPost"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:drawablePadding="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:text="@string/you_can_post_video"
        android:textColor="@android:color/black"
        app:drawableEndCompat="@drawable/ic_check_circle"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/imagePost" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/mixing"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:drawablePadding="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:text="@string/you_can_merge_audio_in_video_or_image"
        android:textColor="@android:color/black"
        app:drawableEndCompat="@drawable/ic_check_circle"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/videoPost" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/musicSystem"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:drawablePadding="@dimen/_10sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:text="@string/you_can_merge_audio_from_device_and_online_both"
        android:textColor="@android:color/black"
        app:drawableEndCompat="@drawable/ic_check_circle"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/mixing" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/activeStatus"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_30sdp"
        android:layout_marginBottom="@dimen/_20sdp"
        android:background="@drawable/rounded_corners"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:minHeight="@dimen/_20sdp"
        android:paddingHorizontal="@dimen/_10sdp"
        android:text="@string/subscribed"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@android:color/holo_green_dark"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/musicSystem" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/upgradeBtn"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_30sdp"
        android:layout_marginBottom="@dimen/_20sdp"
        android:background="@drawable/rounded_corners"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:minWidth="@dimen/_90sdp"
        android:minHeight="@dimen/_24sdp"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="0dp"
        android:text="@string/upgrade"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:backgroundTint="@android:color/holo_red_dark"
        app:layout_constraintEnd_toEndOf="@id/packageTv"
        app:layout_constraintStart_toStartOf="@id/packageTv"
        app:layout_constraintTop_toBottomOf="@id/musicSystem" />


</androidx.constraintlayout.widget.ConstraintLayout>