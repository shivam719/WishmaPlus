        android:layout_marginTop="@dimen/_3sdp"

        android:src="@drawable/user_icon"
        app:layout_constraintStart_toStartOf="@id/likeBtn"
        app:layout_constraintTop_toBottomOf="@id/likeBtn" />


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/replyTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_5sdp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:textColor="@android:color/black"
        android:text="User Name Parent Name Comment"
        app:layout_constraintBottom_toBottomOf="@id/profileReply"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/profileReply"
        app:layout_constraintTop_toTopOf="@id/profileReply" />-->

