<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.VideoEditActivity">

    <androidx.media3.ui.PlayerView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_centerInParent="true"
        android:background="@android:color/black"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:show_next_button="false"
        app:show_previous_button="false"
        app:use_controller="false" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@android:color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/contentView"
        style="@style/TextAppearance.AppCompat.Headline"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/colorPrimaryLight"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:padding="@dimen/_10sdp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBlurView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/blur_gradient_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_arrow_back"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/user_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/story"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/back_button" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/deleteBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_5sdp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"
            android:padding="@dimen/_10sdp"
            android:paddingTop="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp"
            android:paddingBottom="@dimen/_5sdp"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/back_button"
            app:srcCompat="@drawable/ic_delete"
            app:tint="@android:color/white" />

        <com.infotech.wishmaplus.Utils.StoryProgressView.StoriesProgressView
            android:id="@+id/stories"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_3sdp"
            android:layout_gravity="top"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/back_button" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/profile"
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:layout_gravity="center"
            android:layout_margin="@dimen/_10sdp"
            android:src="@drawable/user_icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/nameTv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stories" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/nameTv"
            style="@style/TextAppearance.AppCompat.Body2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_10sdp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@android:color/white"
            app:layout_constraintBottom_toTopOf="@id/timeTv"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/profile"
            app:layout_constraintTop_toTopOf="@id/profile"
            app:layout_constraintVertical_chainStyle="packed" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/timeTv"
            style="@style/TextAppearance.AppCompat.Caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_1sdp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/grey_2"
            app:layout_constraintBottom_toBottomOf="@id/profile"
            app:layout_constraintEnd_toEndOf="@id/nameTv"
            app:layout_constraintStart_toStartOf="@id/nameTv"
            app:layout_constraintTop_toBottomOf="@id/nameTv" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/postTxt"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:autoLink="all"
        android:background="@color/black_alpha_55"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:padding="@dimen/_15sdp"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <!--<androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBlurView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/black_alpha_55"
        android:paddingTop="@dimen/_10sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/postTxt"
            style="@style/TextAppearance.AppCompat.Body2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:autoLink="all"
            android:fontFamily="sans-serif-medium"
            android:textColor="@android:color/white"
            app:layout_constraintBottom_toTopOf="@id/barrier"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:barrierDirection="top"
            app:constraint_referenced_ids="like_count, comment_count,share_count"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/like_count"
            style="@style/TextAppearance.AppCompat.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_2sdp"
            android:drawablePadding="@dimen/_5sdp"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:text="0"
            android:textColor="@color/red_text"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_like"
            app:layout_constraintBottom_toTopOf="@id/likeBtn"
            app:layout_constraintStart_toStartOf="parent" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/comment_count"
            style="@style/TextAppearance.AppCompat.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/_8sdp"
            android:layout_marginBottom="@dimen/_2sdp"
            android:fontFamily="sans-serif-medium"
            android:text="0 Comment"
            android:textColor="@color/grey_1"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/likeBtn"
            app:layout_constraintEnd_toStartOf="@id/share_count"
            app:layout_constraintHorizontal_bias="1" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/share_count"
            style="@style/TextAppearance.AppCompat.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_2sdp"
            android:fontFamily="sans-serif-medium"
            android:text="0 Share"
            android:textColor="@color/grey_1"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/likeBtn"
            app:layout_constraintEnd_toEndOf="parent" />



        <com.google.android.material.button.MaterialButton
            android:id="@+id/likeBtn"
            style="@style/TextAppearance.Compat.Notification.Info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:minHeight="@dimen/_20sdp"
            android:paddingHorizontal="0dp"
            android:paddingVertical="@dimen/_8sdp"
            android:text="Like"
            android:textAlignment="textStart"
            android:textAllCaps="false"
            android:textColor="@color/grey_1"
            app:icon="@drawable/ic_liked_thumbs"
            app:iconPadding="@dimen/_5sdp"
            app:iconSize="@dimen/_12sdp"
            app:iconTint="@color/grey_1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/commentBtn"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/commentBtn"
            style="@style/TextAppearance.Compat.Notification.Info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:minHeight="@dimen/_20sdp"
            android:paddingHorizontal="0dp"
            android:paddingVertical="@dimen/_8sdp"
            android:text="Comment"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textColor="@color/grey_1"
            app:icon="@drawable/ic_comment"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/_5sdp"
            app:iconSize="@dimen/_12sdp"
            app:iconTint="@color/grey_1"
            app:layout_constraintBottom_toBottomOf="@id/likeBtn"
            app:layout_constraintEnd_toStartOf="@id/whatsAppBtn"
            app:layout_constraintHorizontal_weight="1.3"
            app:layout_constraintStart_toEndOf="@id/likeBtn"
            app:layout_constraintTop_toTopOf="@id/likeBtn" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/whatsAppBtn"
            style="@style/TextAppearance.Compat.Notification.Info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:minHeight="@dimen/_20sdp"
            android:paddingHorizontal="0dp"
            android:paddingVertical="@dimen/_8sdp"
            android:text="Send"
            android:textAllCaps="false"
            android:textColor="@color/grey_1"
            app:icon="@drawable/ic_whatsapp"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/_5sdp"
            app:iconSize="@dimen/_12sdp"
            app:iconTint="@color/grey_1"
            app:layout_constraintBottom_toBottomOf="@id/likeBtn"
            app:layout_constraintEnd_toStartOf="@id/shareBtn"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/commentBtn"
            app:layout_constraintTop_toTopOf="@id/likeBtn" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shareBtn"
            style="@style/TextAppearance.Compat.Notification.Info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_10sdp"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-medium"
            android:minHeight="@dimen/_20sdp"
            android:paddingHorizontal="0dp"
            android:paddingVertical="@dimen/_8sdp"
            android:text="Share"
            android:textAlignment="textEnd"
            android:textAllCaps="false"
            android:textColor="@color/grey_1"
            app:icon="@drawable/ic_share"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/_5sdp"
            app:iconSize="@dimen/_12sdp"
            app:iconTint="@color/grey_1"
            app:layout_constraintBottom_toBottomOf="@id/likeBtn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/whatsAppBtn"
            app:layout_constraintTop_toTopOf="@id/likeBtn" />
    </androidx.constraintlayout.widget.ConstraintLayout>-->
</androidx.constraintlayout.widget.ConstraintLayout>