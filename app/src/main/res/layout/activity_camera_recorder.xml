<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ══════════════════════════════════════════════════════
         FULL-SCREEN CAMERA PREVIEW
    ══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/cameraFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Filter / Beauty overlay -->
        <View
            android:id="@+id/filterOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="@android:color/transparent" />

    </FrameLayout>

    <!-- ══════════════════════════════════════════════════════
         RECORDING PROGRESS BAR  (top, red fill)
    ══════════════════════════════════════════════════════ -->
    <View
        android:id="@+id/recordingProgressBar"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="#FF3B30"
        android:scaleX="0"
        android:transformPivotX="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══════════════════════════════════════════════════════
         COUNTDOWN OVERLAY  (fullscreen, topmost)
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/countdownOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#AA000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="@android:color/white"
            android:textSize="120sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Recording shuru hone wali hai..."
            android:textColor="#CCFFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         TOP BAR: Close (left) | Flash (right-ish, center)
    ══════════════════════════════════════════════════════ -->

    <!-- Close button -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="6dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <!-- Flash button -->
    <ImageButton
        android:id="@+id/btnFlash"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="6dp"
        android:src="@drawable/flash_off"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <!-- ══════════════════════════════════════════════════════
         RECORDING TOP BAR  (REC dot + timer) — center, below status
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/recordingTopBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:background="#88000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/recordingIndicatorDot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:layout_marginEnd="6dp"
            android:background="#FF3B30" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="REC"
            android:textColor="#FF3B30"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecordingTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         LEFT SIDE OPTIONS PANEL
         (Music | Speed | Filter | Timer | Beauty)
         — always visible when not recording
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/leftOptionsPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Add Music -->
        <LinearLayout
            android:id="@+id/btnAddMusic"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvMusicName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Music"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center" />
        </LinearLayout>

        <!-- Speed -->
        <LinearLayout
            android:id="@+id/btnSpeed"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_media_ff"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvSpeedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="1x"
                android:textColor="@android:color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Filter -->
        <LinearLayout
            android:id="@+id/btnFilter"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_slideshow"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Filter"
                android:textColor="@android:color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Timer -->
        <LinearLayout
            android:id="@+id/btnTimer"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvTimerValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Off"
                android:textColor="@android:color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Beauty -->
        <LinearLayout
            android:id="@+id/btnBeauty"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvBeautyValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Beauty"
                android:textColor="@android:color/white"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         BOTTOM BAR: Gallery (left) | Record (center) | Flip (right)
         ★ Gallery aur Flip dono standard 44dp size
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="10dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Gallery — standard size, left -->
        <ImageButton
            android:id="@+id/btnGallery"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/rounded_border_bg"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@android:color/white" />

        <!-- Record Button — center, prominent -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="4">

            <View
                android:layout_gravity="center"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/record_outer_ring" />

            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/record_inner_circle"
                android:padding="12dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="@android:color/white" />
        </FrameLayout>

        <!-- Flip Camera — standard size, right (moved from top) -->
        <ImageButton
            android:id="@+id/btnFlipCamera"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_rotate"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         DURATION BAR  (above bottom bar)
         15s | 30s | 60s | 3min — always visible unless recording
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/durationBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="#66000000"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingVertical="5dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/dur15s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:text="15s"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/dur30s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:text="30s"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/dur60s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FF3B30"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:text="60s"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dur3min"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="5dp"
            android:text="3 min"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         SPEED PANEL  (slides above bottom bar)
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/speedPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#EE000000"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:text="Recording Speed"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView android:id="@+id/speed03x"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:text="0.3x" android:textColor="#AAFFFFFF" android:textSize="14sp" />

            <TextView android:id="@+id/speed05x"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:text="0.5x" android:textColor="#AAFFFFFF" android:textSize="14sp" />

            <TextView android:id="@+id/speed1x"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:text="1x" android:textColor="#FFFFFFFF" android:textSize="17sp"
                android:textStyle="bold" />

            <TextView android:id="@+id/speed2x"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:text="2x" android:textColor="#AAFFFFFF" android:textSize="14sp" />

            <TextView android:id="@+id/speed3x"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:paddingHorizontal="14dp" android:paddingVertical="8dp"
                android:text="3x" android:textColor="#AAFFFFFF" android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         TIMER PANEL
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/timerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#EE000000"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:text="Countdown Timer"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView android:id="@+id/timerOff"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:background="#44FFFFFF"
                android:paddingHorizontal="18dp" android:paddingVertical="8dp"
                android:text="Off" android:textColor="#FFFFFFFF" android:textSize="15sp"
                android:textStyle="bold" />

            <TextView android:id="@+id/timer3s"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:paddingHorizontal="18dp" android:paddingVertical="8dp"
                android:text="3s" android:textColor="#AAFFFFFF" android:textSize="15sp" />

            <TextView android:id="@+id/timer10s"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:paddingHorizontal="18dp" android:paddingVertical="8dp"
                android:text="10s" android:textColor="#AAFFFFFF" android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         BEAUTY PANEL
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/beautyPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#EE000000"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Skin Smooth"
                android:textColor="@android:color/white" android:textSize="13sp" />
            <TextView android:id="@+id/tvBeautySmoothVal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="50" android:textColor="#FF3B30" android:textSize="13sp" />
        </LinearLayout>

        <SeekBar android:id="@+id/seekBeautySmooth"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="14dp" android:max="100" android:progress="50" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Whitening"
                android:textColor="@android:color/white" android:textSize="13sp" />
            <TextView android:id="@+id/tvBeautyWhitenVal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="30" android:textColor="#FF3B30" android:textSize="13sp" />
        </LinearLayout>

        <SeekBar android:id="@+id/seekBeautyWhiten"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="100" android:progress="30" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════
         FILTER PANEL
    ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/filterPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#EE000000"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="Filters"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/filterList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp" />
        </HorizontalScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>