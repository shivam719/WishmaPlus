<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/videoV"
    android:layout_height="match_parent"
    tools:context=".Activity.VideoEditActivity">


    <androidx.media3.ui.PlayerView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_centerInParent="true"
        android:background="@android:color/black"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:show_next_button="false"
        app:show_previous_button="false" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBlurView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/blur_gradient_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_arrow_back"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/user_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/video"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toStartOf="@id/moreBTn"
            app:layout_constraintStart_toEndOf="@id/back_button"
            app:layout_constraintTop_toTopOf="@id/back_button" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/moreBTn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_5sdp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"
            android:padding="@dimen/_10sdp"
            android:paddingTop="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp"
            android:paddingBottom="@dimen/_5sdp"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/user_title"
            app:layout_constraintTop_toTopOf="@id/back_button"
            app:srcCompat="@drawable/ic_more_vert"
            app:tint="@android:color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>


    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/profile"
        android:layout_width="@dimen/_35sdp"
        android:layout_height="@dimen/_35sdp"
        android:layout_gravity="center"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:src="@drawable/user_icon"
        app:layout_constraintBottom_toTopOf="@id/postTxt"
        app:layout_constraintEnd_toStartOf="@id/nameTv"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/nameTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/timeTv"
        app:layout_constraintEnd_toStartOf="@id/whatsAppBtn"
        app:layout_constraintStart_toEndOf="@id/profile"
        app:layout_constraintTop_toTopOf="@id/profile"
        app:layout_constraintVertical_chainStyle="packed" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/timeTv"
        style="@style/TextAppearance.AppCompat.Caption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_1sdp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/grey_2"
        app:layout_constraintBottom_toBottomOf="@id/profile"
        app:layout_constraintEnd_toEndOf="@id/nameTv"
        app:layout_constraintStart_toStartOf="@id/nameTv"
        app:layout_constraintTop_toBottomOf="@id/nameTv" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/postTxt"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:autoLink="all"
        android:fontFamily="sans-serif-medium"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/whatsAppBtn"
        app:layout_constraintStart_toStartOf="parent" />


    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/likeBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:minWidth="@dimen/_50sdp"
        android:minHeight="@dimen/_20sdp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/likeBtnTv"
        app:layout_constraintEnd_toEndOf="@id/whatsAppBtn"
        app:layout_constraintStart_toStartOf="@id/whatsAppBtn"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="1"
        app:layout_constraintVertical_chainStyle="packed"
        app:srcCompat="@drawable/ic_liked_thumbs"
        app:tint="@android:color/white" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/likeBtnTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="0"
        android:visibility="gone"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/commentBtn"
        app:layout_constraintEnd_toEndOf="@id/likeBtn"
        app:layout_constraintStart_toStartOf="@id/likeBtn"
        app:layout_constraintTop_toBottomOf="@id/likeBtn" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/commentBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_20sdp"
        android:background="@android:color/transparent"
        android:minWidth="@dimen/_50sdp"
        android:minHeight="@dimen/_20sdp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/commentBtnTv"
        app:layout_constraintEnd_toEndOf="@id/whatsAppBtn"
        app:layout_constraintStart_toStartOf="@id/whatsAppBtn"
        app:layout_constraintTop_toBottomOf="@id/likeBtnTv"
        app:srcCompat="@drawable/ic_comment"
        app:tint="@android:color/white" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/commentBtnTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="0"
        android:visibility="gone"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/shareBtn"
        app:layout_constraintEnd_toEndOf="@id/commentBtn"
        app:layout_constraintStart_toStartOf="@id/commentBtn"
        app:layout_constraintTop_toBottomOf="@id/commentBtn" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/shareBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_20sdp"
        android:background="@android:color/transparent"
        android:minWidth="@dimen/_50sdp"
        android:minHeight="@dimen/_20sdp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/shareBtnTv"
        app:layout_constraintEnd_toEndOf="@id/whatsAppBtn"
        app:layout_constraintStart_toStartOf="@id/whatsAppBtn"
        app:layout_constraintTop_toBottomOf="@id/commentBtnTv"
        app:srcCompat="@drawable/ic_share"
        app:tint="@android:color/white"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/shareBtnTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="0"
        android:visibility="gone"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/whatsAppBtn"
        app:layout_constraintEnd_toEndOf="@id/shareBtn"
        app:layout_constraintStart_toStartOf="@id/shareBtn"
        app:layout_constraintTop_toBottomOf="@id/shareBtn" />
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/whatsAppBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_20sdp"
        android:background="@android:color/transparent"
        android:minWidth="@dimen/_50sdp"
        android:minHeight="@dimen/_20sdp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@id/whatsappBtnTv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/nameTv"
        app:layout_constraintTop_toBottomOf="@id/shareBtnTv"

        app:srcCompat="@drawable/ic_whatsapp"
        app:tint="@android:color/white"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/whatsappBtnTv"
        style="@style/TextAppearance.AppCompat.Body2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:layout_marginBottom="@dimen/_10sdp"
        android:includeFontPadding="false"
        android:text="Send"
        app:layout_constraintVertical_bias="1"
        android:textColor="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/whatsAppBtn"
        app:layout_constraintStart_toStartOf="@id/whatsAppBtn"
        app:layout_constraintTop_toBottomOf="@id/whatsAppBtn" />
</androidx.constraintlayout.widget.ConstraintLayout>