<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="@dimen/_140sdp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="@dimen/_5sdp"
        android:layout_marginHorizontal="@dimen/_10sdp"
        app:cardCornerRadius="@dimen/_8sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/edit"
                style="@style/TextAppearance.AppCompat.Subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/_7sdp"
                android:fontFamily="sans-serif-medium"
                android:padding="@dimen/_12sdp"
                android:text="@string/edit"
                android:textColor="@android:color/black"
                app:drawableStartCompat="@drawable/ic_edit" />

            <View
                android:id="@+id/editLine"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:background="@color/grey_3" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/delete"
                style="@style/TextAppearance.AppCompat.Subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/_7sdp"
                android:fontFamily="sans-serif-medium"
                android:padding="@dimen/_12sdp"
                android:text="@string/delete"
                android:textColor="@android:color/black"
                app:drawableStartCompat="@drawable/ic_delete" />

            <View
                android:id="@+id/deleteLine"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:background="@color/grey_3" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/copyLink"
                style="@style/TextAppearance.AppCompat.Subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/_7sdp"
                android:fontFamily="sans-serif-medium"
                android:padding="@dimen/_12sdp"
                android:text="@string/copy_link"
                android:textColor="@android:color/black"
                app:drawableStartCompat="@drawable/ic_copylink" />

            <View
                android:id="@+id/copyLinkLine"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:background="@color/grey_3" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/report"
                style="@style/TextAppearance.AppCompat.Subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/_7sdp"
                android:fontFamily="sans-serif-medium"
                android:padding="@dimen/_12sdp"
                android:text="@string/report"
                android:textColor="@android:color/black"
                app:drawableStartCompat="@drawable/ic_report" />
            <View
                android:visibility="gone"
                android:id="@+id/videoQualityLine"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:background="@color/grey_3" />
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/videoQuality"
                android:visibility="gone"
                style="@style/TextAppearance.AppCompat.Subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/_7sdp"
                android:fontFamily="sans-serif-medium"
                android:padding="@dimen/_12sdp"
                android:text="Quality Settings"
                android:textColor="@android:color/black"
                app:drawableStartCompat="@drawable/ic_report" />
        </LinearLayout>


    </androidx.cardview.widget.CardView>
</LinearLayout>