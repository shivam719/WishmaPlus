<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rounded_top"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp">
    <View
        android:id="@+id/topLine"
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_3sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        android:layout_gravity="center"
        android:background="@drawable/rounded_corners"
        android:backgroundTint="@color/comment_bg" />

    <!-- Back Button -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <!-- Title Section -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Placements"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>




    <!-- Horizontal Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/_5sdp"
        android:background="#D3D3D3"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Description Section -->
            <TextView
                android:id="@+id/audience_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Additional placements increase the number of people who can see your ad and can improve ad results. Adding more placements does not increase the cost of your ad."
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ads may show in the following places for each platform:"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Advantage+ Audience Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/advantage_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Wishma Plus"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/advantage_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Wishma Plus Stories, Feed, right column, in-stream videos, Instant Articles, search results and video feeds"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Create New Audience Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/create_new_audience_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instagram"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/create_new_audience_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Instagram Stories, Feed, Explore, Reels, in-stream videos"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Estimated Audience Size Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/estimated_audience_size_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Messenger"
                    android:textSize="16sp"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/estimated_audience_size_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sponsored message, Messenger inbox, Messenger stories"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Special Ad Category Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/special_ad_category_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Meta Audience Network"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/special_ad_category_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Banner and interstitial placements"
                    android:textSize="14sp" />
                <TextView
                    android:layout_marginTop="@dimen/_10sdp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Available placements are determined by your ad type and settings. Not all placements are available for every ad. Learn more about placements and see examples of how ads look to potential customers."
                    android:textSize="14sp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
