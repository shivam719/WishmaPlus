<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_top"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#CCCCCC" />

    <!-- Report -->
    <LinearLayout
        android:id="@+id/optReport"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="@color/grey_1">

            <ImageView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_report"
                app:tint="#E03E3E" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Report"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Report inappropriate content"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Not Interested -->
    <LinearLayout
        android:visibility="gone"
        android:id="@+id/optNotInterested"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="@color/grey_1">

            <ImageView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_not_interested"
                app:tint="@color/red" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Not Interested"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="See less content like this"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Copy Link -->
    <LinearLayout
        android:id="@+id/optCopyLink"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="@color/grey_1">

            <ImageView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="center"
                android:padding="@dimen/_2sdp"
                android:src="@drawable/ic_copylink"
                app:tint="#2E6FBE" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Copy Link"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Share this reel with others"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- About Account -->
    <LinearLayout
        android:id="@+id/optAbout"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="@color/grey_1">

            <ImageView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="center"
                android:src="@drawable/info_circle"
                app:tint="@color/dark_blue" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="About This Account"
                android:textColor="#1A1A1A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="View account information"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider — before delete -->
    <View
        android:id="@+id/dividerDelete"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="6dp"
        android:background="#EEEEEE"
        android:visibility="gone" />

    <!-- Delete Reel — visible only when isMyReel=true -->
    <LinearLayout
        android:id="@+id/optDelete"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/circle_bg_red_light">

            <ImageView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:layout_gravity="center"
                android:src="@drawable/ic_delete"
                app:tint="#E03E3E" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Delete Reel"
                android:textColor="#E03E3E"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="This action cannot be undone"
                android:textColor="#F08080"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>