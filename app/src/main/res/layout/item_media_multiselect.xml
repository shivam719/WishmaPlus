<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="1dp">

    <!-- Thumbnail -->
    <ImageView
        android:id="@+id/thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Media thumbnail"/>

    <!-- Dim overlay when selected -->
    <View
        android:id="@+id/selectedOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#550095F6"
        android:visibility="gone"/>

    <!-- Top-right: Checkbox circle -->
    <FrameLayout
        android:id="@+id/checkContainer"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_gravity="top|end"
        android:layout_margin="7dp">

        <!-- Unselected ring -->
        <View
            android:id="@+id/checkRing"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@drawable/check_ring_bg"/>

        <!-- Selected checkmark -->
        <ImageView
            android:id="@+id/checkMark"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_check_circle"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Order number badge (shows when selected) -->
    <TextView
        android:id="@+id/orderBadge"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_margin="9dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textColor="@color/color_white"
        android:textStyle="bold"
        android:background="@drawable/order_badge_bg"
        android:visibility="gone"/>

    <!-- Video duration badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="5dp"
        android:background="@drawable/duration_bg"
        android:paddingHorizontal="5dp"
        android:paddingVertical="2dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/videoIcon"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/ic_play_circle_outline"
            android:layout_marginEnd="3dp"
            app:tint="@color/color_white"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/color_white"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>

</FrameLayout>