<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_top"
    android:padding="16dp"
    android:orientation="vertical">
    <View
        android:id="@+id/topLine"
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_3sdp"
        android:layout_gravity="center"
        android:background="@drawable/rounded_corners"
        android:backgroundTint="@color/comment_bg" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sort groups"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#000"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#12000000"/>

    <!-- Options container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- First option with subtitle -->
        <LinearLayout
            android:visibility="gone"
            android:id="@+id/option_most_visited"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="4dp">

                <TextView
                    android:id="@+id/tvMostVisitedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Most visited"
                    android:textSize="16sp"
                    android:textColor="#000"/>

                <TextView
                    android:id="@+id/tvMostVisitedSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your pinned groups will be shown first. Tap and hold a group to pin it to the top."
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"
                    android:textColor="#6e6e6e"/>
            </LinearLayout>
            <RadioButton
                android:id="@+id/radioMostVisited"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:layout_margin="0dp"
                android:buttonTint="@color/colorPrimary"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text=""
                android:clickable="false"
                android:minWidth="0dp"
                android:minHeight="0dp"/>
        </LinearLayout>

        <!-- Second option -->
        <LinearLayout
            android:id="@+id/option_a_z"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">



            <TextView
                android:id="@+id/tvAZ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Groups A-Z"
                android:textSize="16sp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="#000"/>
            <RadioButton
                android:id="@+id/radioAZ"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:layout_margin="0dp"
                android:buttonTint="@color/colorPrimary"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text=""
                android:clickable="false"
                android:minWidth="0dp"
                android:minHeight="0dp"/>
        </LinearLayout>

        <!-- Third option -->
        <LinearLayout
            android:id="@+id/option_recent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">



            <TextView
                android:id="@+id/tvRecentlyJoined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recently joined"
                android:textSize="16sp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="#000"/>
            <RadioButton
                android:id="@+id/radioRecentlyJoined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:layout_margin="0dp"
                android:buttonTint="@color/colorPrimary"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text=""
                android:clickable="false"
                android:minWidth="0dp"
                android:minHeight="0dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
